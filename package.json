{
  "name": "cf-cuasar-core",
  "version": "0.1.0",
  "description": "VaaIA - Sistema de análisis inmobiliario con IA en Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:frontend": "vite --config src/frontend/vite.config.ts",
    "build": "vite build",
    "build:frontend": "vite build --config src/frontend/vite.config.ts",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "typecheck:frontend": "tsc --noEmit -p src/frontend/tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@tanstack/react-query": "^5.91.0",
    "axios": "^1.13.6",
    "hono": "^4.0.0",
    "lucide-react": "^0.400.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "wrangler": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
